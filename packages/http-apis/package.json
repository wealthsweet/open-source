{
  "name": "@wealthsweet/http-apis",
  "version": "1.4.0",
  "devDependencies": {
    "@types/node": "25.4.0",
    "eslint": "10.0.3",
    "openapi-typescript": "7.13.0",
    "openapi3-ts": "4.5.0",
    "prettier": "3.8.1",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "yaml": "2.8.2",
    "zod": "4.3.6",
    "zod-openapi": "5.4.6"
  },
  "exports": {
    "./performance/zod": {
      "types": "./dist/performance/zod.d.ts",
      "module": "./dist/performance/zod.js"
    },
    "./performance/api": {
      "types": "./dist/performance/api.d.ts",
      "module": "./dist/performance/api.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wealthsweet/open-source.git"
  },
  "scripts": {
    "build": "pnpm gen:swagger && pnpm gen:api && tsup",
    "clean": "rm -r dist || true",
    "clean:full": "rm -r dist node_modules .turbo || true",
    "gen:api": "pnpm openapi-typescript",
    "gen:swagger": "tsx ./src/generate-swagger-files",
    "lint": "eslint",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage.enabled"
  },
  "sideEffects": false,
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  }
}
