{
  "name": "@wealthsweet/embed-message-api",
  "version": "1.2.0",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  },
  "files": [
    "dist/**"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "publishConfig": {
